# Variaveis obrigatorias em producao (Neon + Vercel Marketplace)
# A integracao do Neon normalmente cria DATABASE_URL automaticamente.
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require
BLOB_READ_WRITE_TOKEN=seu-token-do-vercel-blob
FDP_AUTH_SECRET=gere-um-segredo-longo-e-aleatorio

# Opcionais: webhooks e sincronizacoes externas
FDP_EMAIL_TOKEN=
FDP_WHATSAPP_TOKEN=
FDP_TEAMS_TOKEN=
FDP_DRIVE_TOKEN=
FDP_ONEDRIVE_TOKEN=
FDP_ERP_TOKEN=

# Microsoft Graph (Teams e OneDrive; use as tres variaveis juntas)
FDP_MICROSOFT_CLIENT_ID=
FDP_MICROSOFT_TENANT_ID=
FDP_MICROSOFT_CLIENT_SECRET=

# Sankhya Gateway (OAuth2 Client Credentials; X-Token vem do Sankhya Om)
FDP_SANKHYA_BASE_URL=https://api.sankhya.com.br
FDP_SANKHYA_CLIENT_ID=
FDP_SANKHYA_CLIENT_SECRET=
FDP_SANKHYA_X_TOKEN=
FDP_SANKHYA_REQUEST_BODY=
FDP_SANKHYA_METRIC_FIELD_MAP=

# Segredos dos webhooks de entrada (email, WhatsApp e Teams)
FDP_EMAIL_WEBHOOK_SECRET=
FDP_WHATSAPP_WEBHOOK_SECRET=
FDP_TEAMS_WEBHOOK_SECRET=
